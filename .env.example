# Copy to .env and fill in. .env is gitignored — never commit a real key.

# OpenAI — embeddings + answer generation
OPENAI_API_KEY=

# Optional model overrides (defaults live in src/akasha/config.py)
# Keep EMBED_DIM <= 2000 so pgvector can ANN-index the embeddings.
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# EMBED_DIM=1536
# OPENAI_RESPONSE_MODEL=gpt-4o

# --- Local infra (docker-compose.yml reads these too) -------------------
POSTGRES_DB=akasha_rag
POSTGRES_USER=akasha
POSTGRES_PASSWORD=akasha
# If a native Postgres already listens on 5432, use another host port (e.g. 5433)
# here AND in DATABASE_URL below.
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://akasha:akasha@localhost:5432/akasha_rag

REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=akasha-documents
MINIO_ENDPOINT_URL=http://localhost:9000

# --- Auth (dev) ---
# HS256 secret for local dev JWTs. Mint tokens with scripts/dev_token.py.
JWT_SECRET=akasha-local-dev-secret-do-not-use-in-production
